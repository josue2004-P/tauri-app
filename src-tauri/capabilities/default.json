{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-execute",
    "sql:allow-select",
    {
      "identifier": "sql:allow-load",
      "config": {
        "db": "sqlite:datos.db"
      }
    }
  ]
}